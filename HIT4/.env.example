# Copiar este archivo a .env y completar los valores.
# NUNCA commitear .env al repositorio.

# Opcional: forzar modo headless sin pasar --headless como argumento
HEADLESS=false
LOG_LEVEL=info
RESULT_LIMIT=10
MAX_RETRIES=2
EXPLICIT_WAIT_MS=20000
PAGE_LOAD_TIMEOUT_MS=120000
SCRIPT_TIMEOUT_MS=60000
WINDOW_WIDTH=1920
WINDOW_HEIGHT=1080
OUTPUT_DIR=output
LOG_DIR=logs
APPLY_FILTERS=true
PRODUCTS=bicicleta rodado 29|iPhone 16 Pro Max|GeForce RTX 5090
